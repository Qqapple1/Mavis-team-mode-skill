# ShellCheck configuration
# https://github.com/koalaman/shellcheck/blob/master/shellcheckrc

# Set the shell to bash for accurate checking
shell=bash

# Allow optional words like "local" in non-bash scripts
disable=SC3043

# Suggest explicit -n in `[` test (we use it consistently already)
disable=SC2155

# Suggest using cd ... || exit (we handle errors differently)
disable=SC2164

# Don't warn about not using $(...) - we have plenty of $() calls
disable=SC2005

# Use POSIX sh dialect by default
external-sources=true

# Check sourced files
check-sourced=true

# Note: PowerShell scripts (*.ps1) are NOT linted by shellcheck — they have
# a different grammar. CI's Windows job validates PS1 syntax via
# `[System.Management.Automation.Language.Parser]::ParseFile` instead.
# If you run `shellcheck scripts/install.ps1` locally, expect false
# positives on `param(...)` — those are bash-grammar errors, not real bugs.
